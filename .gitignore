# 🔹 Python cache
__pycache__/
*.py[cod]
*$py.class

# 🔹 Virtual environments
venv/
.env/
.env.*

# 🔹 Environment variables
.env
.env.local
.env.development
.env.production

# 🔹 Python packaging
build/
dist/
*.egg-info/
.eggs/

# 🔹 Logs
*.log

# 🔹 SQLite DB (if used locally)
*.db
*.sqlite3

# 🔹 Jupyter Notebook checkpoints
.ipynb_checkpoints/

# 🔹 IDE files
.vscode/
.idea/

# 🔹 OS files
.DS_Store
Thumbs.db

# 🔹 Testing / coverage
.pytest_cache/
.coverage
htmlcov/

# 🔹 FastAPI specific
*.pid

# 🔹 Docker (optional)
*.tar

# 🔹 Mypy / type check
.mypy_cache/

# 🔹 Temporary files
*.tmp
*.swp

